#!/usr/bin/env bash
# RoR Command Center — rorcc CLI
# Local AI bootstrap: scaffold projects and run the Rails specialist team on Ollama.
set -euo pipefail

# Resolve the directory of this script, following symlinks (curl-mode installs
# rorcc into PATH, so we cannot assume CWD).
_src="${BASH_SOURCE[0]}"
while [ -h "$_src" ]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"
  _src="$(readlink "$_src")"
  [[ "$_src" != /* ]] && _src="$_dir/$_src"
done
RORCC_BIN_DIR="$(cd -P "$(dirname "$_src")" && pwd)"
RORCC_HOME="$(cd "$RORCC_BIN_DIR/.." && pwd)"
RORCC_LIB_DIR="$RORCC_HOME/lib/rorcc"

# shellcheck source=/dev/null
. "$RORCC_LIB_DIR/common.sh"

usage() {
  cat <<'EOF'
rorcc — RoR Command Center local AI CLI

USAGE:
  rorcc [command] [args]      (no command → interactive menu)

COMMANDS:
  menu                    Interactive launcher: pick a specialist by number
  init <project>          Scaffold a new project with the .ai/ framework
  init --docker <project> Scaffold a full Dockerized Rails app (MySQL, no local Ruby)
  doctor                  Check Ollama, models, and environment
  build-agent <name>      Compile a .ai/agents/<name>.yaml into an Ollama model
  update [name]           Recompile agents after editing .ai/ (all, or just <name>)
  agent <name> [--cloud]  Chat with an agent (local Ollama by default, --cloud for hybrid)
  skill <name> [--cloud]  Run a .ai/skills/<name> skill with its responsible agent
  workflow <name> [--cloud]  Run a .ai/workflows/<name> end to end, phase by phase
  proxy [--start]         Show IDE (Cursor/Claude Code) config; --start runs a LiteLLM gateway
  uninstall [opts]        Remove what setup.sh installed (agents, CLI, framework; --ollama/--models/--project)
  help                    Show this help

ENVIRONMENT:
  RORCC_MODEL            Base Ollama model (default: qwen2.5-coder:7b)
  OLLAMA_HOST           Ollama endpoint (default: http://localhost:11434)
  RORCC_BACKEND         local | cloud (default: local)
  RORCC_CLOUD_PROVIDER  openai | anthropic (default: openai)
  RORCC_CLOUD_MODEL     cloud model id (e.g. gpt-4o, claude-3-5-sonnet-latest)
  OPENAI_API_KEY / ANTHROPIC_API_KEY   cloud credentials

EXAMPLES:
  rorcc init warehouse-wms
  rorcc init --docker tallerflow
  rorcc doctor
  rorcc build-agent rails-architect
  rorcc agent rails-architect
EOF
}

cmd_init() {
  local docker=0 target=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --docker) docker=1 ;;
      -*) err "unknown option: $1"; return 2 ;;
      *)
        if [ -n "$target" ]; then err "unexpected argument: $1"; return 2; fi
        target="$1"
        ;;
    esac
    shift
  done

  if [ "$docker" -eq 1 ]; then
    . "$RORCC_LIB_DIR/init_docker.sh"
    cmd_init_docker "$target"
    return $?
  fi

  if [ -z "$target" ]; then
    err "usage: rorcc init [--docker] <project-dir>"
    return 2
  fi
  local installer="$RORCC_HOME/install.sh"
  if [ ! -f "$installer" ]; then
    err "install.sh not found at $installer"
    return 1
  fi
  info "Scaffolding '$target' via install.sh"
  "$installer" "$target"
  printf '\n'
  ok "next: cd $target && rorcc doctor"
}

cmd_uninstall() {
  local script="$RORCC_HOME/uninstall.sh"
  if [ ! -f "$script" ]; then
    err "uninstall.sh not found at $script (run from the cloned repo)"
    return 1
  fi
  bash "$script" "$@"
}

main() {
  # No command → friendly interactive menu (built for non-technical users).
  local cmd="${1:-menu}"
  [ $# -gt 0 ] && shift || true
  case "$cmd" in
    menu)         . "$RORCC_LIB_DIR/menu.sh";        cmd_menu "$@" ;;
    init)         cmd_init "$@" ;;
    doctor)       . "$RORCC_LIB_DIR/doctor.sh";      cmd_doctor "$@" ;;
    build-agent)  . "$RORCC_LIB_DIR/build_agent.sh"; cmd_build_agent "$@" ;;
    update)       . "$RORCC_LIB_DIR/build_agent.sh"; cmd_update "$@" ;;
    agent)        . "$RORCC_LIB_DIR/agent.sh";       cmd_agent "$@" ;;
    skill)        . "$RORCC_LIB_DIR/skill.sh";       cmd_skill "$@" ;;
    workflow)     . "$RORCC_LIB_DIR/workflow.sh";    cmd_workflow "$@" ;;
    proxy)        . "$RORCC_LIB_DIR/proxy.sh";       cmd_proxy "$@" ;;
    uninstall)    cmd_uninstall "$@" ;;
    help|-h|--help) usage ;;
    *) err "unknown command: $cmd"; printf '\n'; usage; exit 2 ;;
  esac
}

main "$@"
